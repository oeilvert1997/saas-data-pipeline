# Generated by Home Manager
root=true

[*]
charset=utf-8
end_of_line=lf
indent_size=2
indent_style=space
insert_final_newline=true
trim_trailing_whitespace=true

[*.html,*.css,*.js,*.ts,*.jsx,*.tsx]
indent_size=2

[*.json]
indent_size=2

[*.md]
indent_size=2

[*.nix]
indent_size=2

[*.py,*.ipynb]
indent_size=4

[*.qml]
indent_size=4

[*.yml,*.yaml]
indent_size=2

[Dockerfile]
indent_size=2

